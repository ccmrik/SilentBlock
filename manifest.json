{
  "manifest_version": 3,
  "name": "SilentBlock",
  "version": "1.5.3",
  "description": "Free, silent ad blocker. No ads, no nags, no subscriptions. Ever.",
  "update_url": "https://raw.githubusercontent.com/ccmrik/SilentBlock/main/updates.xml",
  "browser_specific_settings": {
    "gecko": {
      "id": "silentblock@local",
      "strict_min_version": "128.0",
      "update_url": "https://raw.githubusercontent.com/ccmrik/SilentBlock/main/updates.json"
    }
  },
  "permissions": [
    "declarativeNetRequest","declarativeNetRequestFeedback",
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/spoof.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "css": ["content/cosmetic.css"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules/rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-on-16.png",
      "48": "icons/icon-on-48.png",
      "128": "icons/icon-on-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-on-16.png",
    "48": "icons/icon-on-48.png",
    "128": "icons/icon-on-128.png"
  }
}
